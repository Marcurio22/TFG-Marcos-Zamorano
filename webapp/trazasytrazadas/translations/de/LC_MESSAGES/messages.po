msgid "Imagen cargada correctamente."
msgstr "Bild erfolgreich hochgeladen."

#: trazasytrazadas/traces.py:325
msgid "No hay ninguna imagen cargada para borrar."
msgstr "Es ist kein Bild zum Löschen geladen."

#: trazasytrazadas/traces.py:336
msgid "Imagen borrada correctamente."
msgstr "Bild erfolgreich gelöscht."

#: trazasytrazadas/traces.py:360
