#: trazasytrazadas/traces.py:152
msgid "No se ha seleccionado ningún archivo."
msgstr "Nessun file selezionato."

#: trazasytrazadas/traces.py:156
msgid "Formato de archivo no permitido. Usa .jpg, .jpeg o .png."
msgstr "Formato file non consentito. Usa .jpg, .jpeg o .png."

#: trazasytrazadas/templates/index.html:212 trazasytrazadas/traces.py:261
msgid "Estado: ninguna imagen cargada. Inserta una imagen para empezar."
msgstr "Stato: nessuna immagine caricata. Inserisci un'immagine per iniziare."

#: trazasytrazadas/templates/index.html:213 trazasytrazadas/traces.py:266
msgid "Estado: imagen cargada. Pulsa «Calcular trazas»."
msgstr "Stato: immagine caricata. Premi «Calcola tracce»."

#: trazasytrazadas/traces.py:270
msgid "Estado: trazas calculadas. Se dibujarán automáticamente sobre la imagen."
msgstr "Stato: tracce calcolate. Verranno disegnate automaticamente sull'immagine."

#: trazasytrazadas/traces.py:301
msgid "Imagen cargada correctamente."
msgstr "Immagine caricata correttamente."

#: trazasytrazadas/traces.py:316
msgid "No hay ninguna imagen cargada para borrar."
msgstr "Non c'è alcuna immagine caricata da eliminare."

#: trazasytrazadas/traces.py:327
msgid "Imagen borrada correctamente."
msgstr "Immagine eliminata correttamente."

#: trazasytrazadas/traces.py:348
msgid "Primero debes insertar una imagen antes de calcular trazas."
msgstr "Devi prima inserire un'immagine prima di calcolare le tracce."

#: trazasytrazadas/traces.py:359
#, python-format
msgid "Error ejecutando segmentación: %(error)s"
msgstr "Errore durante l'esecuzione della segmentazione: %(error)s"

#: trazasytrazadas/traces.py:365
msgid "Las trazas de la imagen han sido calculadas correctamente."
msgstr "Le tracce dell'immagine sono state calcolate correttamente."

#: trazasytrazadas/traces.py:420
msgid "resultados"
msgstr "risultati"

#: trazasytrazadas/traces.py:467
msgid "No hay trazas calculadas todavía."
msgstr "Non sono ancora state calcolate tracce."

#: trazasytrazadas/traces.py:477
msgid "Archivo de trazas no encontrado. Vuelve a calcularlas."
msgstr "File delle tracce non trovato. Ricalcolale."

