msgid "Las trazas de la imagen han sido calculadas correctamente."
msgstr "The image traces have been calculated successfully."

#: trazasytrazadas/traces.py:397
msgid "No hay trazas calculadas todavía."
msgstr "No traces have been calculated yet."

#: trazasytrazadas/traces.py:407
msgid "Archivo de trazas no encontrado. Vuelve a calcularlas."
msgstr "Traces file not found. Please calculate them again."

